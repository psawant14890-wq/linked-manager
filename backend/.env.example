# Copy this file to .env and fill in real values. Never commit .env itself.

APP_NAME=LinkedIQ
ENV=development
DEBUG=true

# --- Database ---
# Local Docker Postgres (default -- matches docker-compose.yml):
DATABASE_URL=postgresql+asyncpg://linkediq:linkediq@localhost:5432/linkediq
DB_SSL_REQUIRE=false
#
# Supabase (production, free tier) -- use the SESSION POOLER string, not
# the direct connection. Supabase's free-tier direct connection is IPv6-only;
# most PaaS hosts (Render included) only route IPv4 outbound, so the direct
# string will fail to connect. Get the session pooler string from your
# Supabase project: Connect button (top of dashboard) -> "Session pooler" tab.
# It looks like this (note the +asyncpg driver prefix added manually, and
# the project ref embedded in the username as postgres.<ref>):
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# DB_SSL_REQUIRE=true

JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Chat / generation LLM ---
# Zero-cost setup using xAI's Grok API (OpenAI-SDK compatible):
OPENAI_API_KEY=xai-replace-with-your-grok-key
OPENAI_BASE_URL=https://api.x.ai/v1
OPENAI_CHAT_MODEL=grok-4.3
#
# To use OpenAI instead, comment out the two lines above and use:
# OPENAI_API_KEY=sk-replace-with-your-openai-key
# OPENAI_BASE_URL=
# OPENAI_CHAT_MODEL=gpt-4o

# --- Embeddings ---
# Runs 100% locally via fastembed -- no API key, no cost, regardless of
# which chat provider you use above.
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- CORS ---
# Local dev default. In production, set this to your deployed frontend's
# real URL (e.g. https://linkediq.vercel.app) or the backend will reject
# the frontend's requests.
FRONTEND_ORIGIN=http://localhost:3000

MAX_UPLOAD_SIZE_BYTES=26214400
